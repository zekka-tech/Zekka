{
  "name": "zekka-framework",
  "version": "3.2.2",
  "description": "Enterprise-grade AI orchestration platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "tsc",
    "type-check:backend": "tsc --noEmit",
    "type-check": "npm run type-check:backend && npm --prefix frontend run type-check",
    "build:watch": "tsc --watch",
    "test": "jest --verbose --runInBand",
    "test:coverage": "jest --coverage --verbose --runInBand",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:integration": "jest --testPathPatterns=tests/integration --runInBand",
    "test:e2e": "jest --testPathPatterns=tests/e2e --runInBand",
    "test:watch": "jest --watch",
    "verify:entrypoints": "node scripts/verify-entrypoints.js",
    "verify:ci": "npm run type-check && npm run verify:entrypoints && npm test && npm run build && npm --prefix frontend run test:run && npm --prefix frontend run build",
    "lint:repo": "npm run lint && npm --prefix frontend run lint",
    "verify:quality": "node scripts/run-quality-report.js",
    "verify:quality:strict": "npm run type-check && npm run verify:entrypoints && npm run lint:repo",
    "test:security": "./test-security.sh",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "migrate": "node src/cli/migrate.js",
    "migrate:status": "node src/cli/migrate.js status",
    "migrate:create": "node src/cli/migrate.js create",
    "migrate:rollback": "node src/cli/migrate.js rollback",
    "migrate:verify": "node src/cli/migrate.js verify",
    "load-test": "k6 run load-tests/k6-load-test.js",
    "load-test:artillery": "artillery run load-tests/artillery-config.yml",
    "load-test:smoke": "k6 run --vus 1 --duration 1m load-tests/k6-load-test.js",
    "load-test:stress": "k6 run --vus 100 --duration 5m load-tests/k6-load-test.js",
    "metrics": "node src/cli/metrics.js",
    "backup": "node src/cli/backup.js",
    "restore:db": "./scripts/restore-database.sh",
    "validate:env": "node scripts/validate-environment.js",
    "docs:generate": "node scripts/generate-swagger-docs.js",
    "docker:build": "docker build -t zekka-framework:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:test": "docker-compose -f docker-compose.test.yml up --abort-on-container-exit",
    "docker:clean": "docker-compose down -v",
    "secrets:generate": "node scripts/generate-secrets.js",
    "security:scan": "node scripts/security-scan.js",
    "security:scan:ci": "node scripts/security-scan.js --ci",
    "backup:db": "./scripts/backup-database.sh",
    "setup:production": "npm run secrets:generate && npm run validate:env && npm run migrate && npm run test:security",
    "security:zap": "node scripts/zap-scan.js --mode baseline",
    "security:zap:full": "node scripts/zap-scan.js --mode full",
    "security:zap:api": "node scripts/zap-scan.js --mode api",
    "security:snyk": "snyk test --severity-threshold=high",
    "security:snyk:monitor": "snyk monitor",
    "security:audit": "npm audit --audit-level=moderate && npm run security:scan && npm run security:snyk",
    "alert:test": "node scripts/alert-notify.js --channel all --severity info --title 'Test Alert' --message 'This is a test alert'",
    "alert:send": "node scripts/alert-notify.js",
    "profile:cpu": "node --cpu-prof --cpu-prof-dir=./profiles src/index.js",
    "profile:memory": "node --heap-prof --heap-prof-dir=./profiles src/index.js",
    "sonar:scan": "sonar-scanner",
    "ops:health": "node scripts/ops-health-check.js",
    "ops:monitor": "node scripts/ops-monitor.js",
    "ops:rollback": "node scripts/ops-rollback.js",
    "k8s:apply": "kubectl apply -f k8s/",
    "k8s:deploy:alama": "kubectl apply -f k8s/alama-hpa.yaml -f k8s/alama-deployment.yaml",
    "k8s:deploy:postgres": "kubectl apply -f k8s/postgresql-ha.yaml",
    "k8s:status": "kubectl get pods,svc,hpa -n zekka-production"
  },
  "keywords": [
    "ai",
    "orchestration",
    "framework",
    "enterprise",
    "typescript",
    "microservices"
  ],
  "author": "Zekka Technologies",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.978.0",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bull": "^4.12.0",
    "compression": "^1.7.4",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "fuse.js": "^7.4.2",
    "geoip-lite": "^2.0.3",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.5.2",
    "luxon": "^3.4.4",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.3",
    "opossum": "^10.0.0",
    "pg": "^8.22.0",
    "prism-react-renderer": "^2.4.1",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "artillery": "^2.0.21",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "snyk": "^1.1305.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~6.0.3",
    "zaproxy": "^2.0.0-rc.7",
    "@eslint/js": "^9.39.2",
    "@eslint/eslintrc": "^3.3.3",
    "globals": "^16.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.+(ts|tsx|js)",
      "**/?(*.)+(spec|test).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/**/*.d.ts",
      "!src/cli/**",
      "!src/types/**"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@middleware/(.*)$": "<rootDir>/src/middleware/$1",
      "^@routes/(.*)$": "<rootDir>/src/routes/$1",
      "^@types/(.*)$": "<rootDir>/src/types/$1",
      "^@utils/(.*)$": "<rootDir>/src/utils/$1",
      "^@config/(.*)$": "<rootDir>/src/config/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testTimeout": 30000
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "bull": {
      "uuid": "^11.1.1"
    }
  }
}
