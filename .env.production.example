# Backend compose environment
# Copy to .env.production before running docker compose.

NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# App security
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters-long
ENCRYPTION_KEY=replace-with-64-hex-characters
JWT_EXPIRATION=24h

# Database used by the compose stack
DB_HOST=postgres
DB_PORT=5432
DB_NAME=zekka_production
DB_USER=zekka_user
DB_PASSWORD=<generate: openssl rand -hex 32>
DATABASE_URL=postgresql://zekka_user:<DB_PASSWORD>@postgres:5432/zekka_production?sslmode=disable

# Redis used by the compose stack
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<generate: openssl rand -hex 32>

# Monitoring
GRAFANA_ADMIN_PASSWORD=<generate: openssl rand -hex 16>

# Optional external providers
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434
DEFAULT_MODEL=ollama
MAX_CONCURRENT_AGENTS=10
DAILY_BUDGET=50
MONTHLY_BUDGET=1000

# Optional Vault wiring
VAULT_ENABLED=false
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
