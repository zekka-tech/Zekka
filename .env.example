# Legacy convenience template.
# Prefer:
# - .env.example.secure for running the backend directly
# - .env.production.example for docker compose

NODE_ENV=development
PORT=3000

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters-long
ENCRYPTION_KEY=replace-with-64-hex-characters

DATABASE_URL=postgresql://zekka_user:changeme@localhost:5432/zekka
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

GITHUB_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=ollama
MAX_CONCURRENT_AGENTS=10

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DAILY_BUDGET=50
MONTHLY_BUDGET=1000
